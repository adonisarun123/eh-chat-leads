# ── Supabase ───────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in real values.
#
# IMPORTANT: This app reads Supabase SERVER-SIDE (in a Next.js Route Handler),
# so the key is NEVER shipped to the browser. That protects the phone numbers
# and lead PII in chatbot_sessions even if your Row Level Security is loose.
#
# Because the read is server-side, the variables are NOT prefixed NEXT_PUBLIC_.

SUPABASE_URL=https://avyqnryaqgfzxgqtlsxp.supabase.co

# The publishable key works for reads if RLS grants the anon/public role SELECT.
# If your RLS blocks anon, use a SERVICE ROLE key here instead (server-side only,
# never exposed to the browser). Prefer the least-privileged key that works.
SUPABASE_KEY=sb_publishable_TN4-D-LDv4pYqxNnOcGMFg_diZhb5wH

# Table to read
SUPABASE_TABLE=chatbot_sessions
